# API Configuration

# Base URL for the PMR API server.
VITE_API_BASE_URL=http://localhost:9380

# API endpoint for downloading COMBINE archives and workspace archives.
VITE_DOWNLOAD_API=http://localhost:8787

# Google Analytics Configuration
# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=

# GitHub OAuth Configuration
# Visit github.com/settings/developers to create a new OAuth app.
VITE_GITHUB_CLIENT_ID=

# Base URL for the GitHub OAuth authentication API server.
VITE_GITHUB_AUTH_API=http://localhost:8788
